{
  "name": "mc-texture-browser",
  "displayName": "MC Texture Browser",
  "description": "Browse and copy Minecraft Bedrock vanilla texture paths instantly",
  "version": "0.1.1",
  "publisher": "finearts",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "keywords": [
    "minecraft",
    "bedrock",
    "textures",
    "addon",
    "marketplace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AngelGomezFine/mc-texture-browser"
  },
  "homepage": "https://github.com/AngelGomezFine/mc-texture-browser#readme",
  "bugs": {
    "url": "https://github.com/AngelGomezFine/mc-texture-browser/issues"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mc-texture-browser-sidebar",
          "title": "MC Texture Browser",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "mc-texture-browser-sidebar": [
        {
          "id": "mc-texture-browser.welcomeView",
          "name": "MC Textures",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "mc-texture-browser.welcomeView",
        "contents": "Browse and copy Minecraft Bedrock vanilla texture paths.\n\n[Open Texture Browser](command:mc-texture-browser.open)"
      }
    ],
    "commands": [
      {
        "command": "mc-texture-browser.open",
        "title": "MC Texture Browser: Open",
        "icon": "$(symbol-file)"
      }
    ],
    "keybindings": [
      {
        "command": "mc-texture-browser.open",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mc-texture-browser.open",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "fetch-textures": "node scripts/fetch-textures.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}